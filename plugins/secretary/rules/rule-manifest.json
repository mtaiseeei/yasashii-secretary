{
  "schemaVersion": 1,
  "entrypoint": "plain-language.md",
  "priority": [
    "safety",
    "evidence",
    "common-language",
    "yasashii-style"
  ],
  "rules": {
    "evidence": {
      "path": "evidence.md",
      "owner": "common-core",
      "protected": true,
      "dependencies": []
    },
    "safety": {
      "path": "safety.md",
      "owner": "common-core",
      "protected": true,
      "dependencies": [
        "evidence"
      ]
    },
    "common-language": {
      "path": "common-language.md",
      "owner": "common-core",
      "protected": true,
      "dependencies": [
        "evidence"
      ]
    },
    "yasashii-style": {
      "path": "styles/yasashii.md",
      "owner": "yasashii-overlay",
      "protected": false,
      "dependencies": [
        "evidence",
        "safety",
        "common-language"
      ],
      "copy": "copy/yasashii.json",
      "copySurfaces": [
        "conversation",
        "diagnosis",
        "report",
        "developerHandoff"
      ],
      "overrides": []
    }
  },
  "forbiddenStyleOverrides": [
    "memoryProtection",
    "secretHandling",
    "evidenceRequirements",
    "confirmationBoundary",
    "pushBoundary",
    "wizardCopy",
    "wizardBehavior",
    "oauthScope",
    "syncBoundary"
  ]
}
